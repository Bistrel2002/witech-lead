# ==========================================
# WITECH LEAD ENVIRONMENT CONFIGURATIONS
# ==========================================

# 1. API Ports & Environment
PORT=3001
NODE_ENV=development

# 2. Main CRM Database Configuration
# Leave blank to fallback to local database.sqlite
DATABASE_URL=postgresql://crm_admin:crm_secure_password@localhost:5432/witech_crm

# 3. External French Business Database (Read-Only)
# Keeps CRM database lightweight (<2GB). Can point to external schema.
FRENCH_DB_URL=postgresql://crm_admin:crm_secure_password@localhost:5432/witech_crm

# 4. Authentication & JWT Sessions
JWT_SECRET=witech-crm-token-key-2026

# 5. Developer Bypass (Bypass Apple/Google Login locally)
# Set to 'true' to auto-login mock dev credentials
VITE_MOCK_AUTH=true

# 6. Hidden Portals Secret Access Passwords
ADMIN_PORTAL_PASSWORD=admin123
TEAM_PORTAL_PASSWORD=team123

# 7. HashiCorp Vault Connection
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=witech-vault-token
VAULT_SECRET_PATH=witech-crm

# 8. S3-Compatible Storage (AWS S3 or MinIO)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=witech-backups
S3_ACCESS_KEY_ID=backup_admin
S3_SECRET_ACCESS_KEY=minio_secure_password
S3_REGION=us-east-1
# FERNET_KEY=  (Leave blank to auto-generate and store in Vault on first backup)
